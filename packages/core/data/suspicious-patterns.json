{
  "_description": "Regex patterns for detecting prompt injection attempts. Flags: gi (global, case-insensitive). Optional 'severity' field per pattern (defaults to 'danger' when omitted) lets us add lower-confidence signals (e.g. generic 'Human:' turn markers) without inflating the danger count.",
  "patterns": [
    { "name": "Instruction override attempt", "pattern": "ignore\\s+(?:all\\s+)?(?:previous|prior|above|earlier|preceding)\\s+(?:instructions?|prompts?|rules?|guidelines?|directives?)", "flags": "gi" },
    { "name": "Instruction override attempt", "pattern": "disregard\\s+(?:all\\s+)?(?:previous|prior|above|earlier)\\s+(?:instructions?|prompts?|rules?)", "flags": "gi" },
    { "name": "Context reset attempt", "pattern": "forget\\s+(?:all\\s+)?(?:previous|prior|your)\\s+(?:instructions?|prompts?|rules?|context)", "flags": "gi" },
    { "name": "Role reassignment attempt", "pattern": "you\\s+are\\s+now\\s+(?:a|an|the)\\s+", "flags": "gi" },
    { "name": "Role reassignment attempt", "pattern": "act\\s+as\\s+(?:if\\s+you\\s+(?:are|were)|a|an|the)", "flags": "gi" },
    { "name": "Role reassignment attempt", "pattern": "pretend\\s+(?:to\\s+be|you\\s+are|that)", "flags": "gi" },
    { "name": "System prompt injection", "pattern": "new\\s+(?:system\\s+)?instructions?\\s*:", "flags": "gi" },
    { "name": "System prompt injection", "pattern": "system\\s*:\\s*you\\s+(?:are|must|should|will)", "flags": "gi" },
    { "name": "Authority impersonation", "pattern": "\\[(?:system|admin|root|developer)\\]", "flags": "gi" },
    { "name": "Privilege escalation attempt", "pattern": "(?:admin|root|developer|system)\\s+(?:mode|access|override)", "flags": "gi" },
    { "name": "Instruction bypass attempt", "pattern": "do\\s+not\\s+(?:follow|obey|listen\\s+to)\\s+(?:your|the|any)", "flags": "gi" },
    { "name": "Override attempt", "pattern": "override\\s+(?:your|the|all|safety|security)\\s+", "flags": "gi" },
    { "name": "Bypass attempt", "pattern": "bypass\\s+(?:your|the|all|safety|security|content)\\s+", "flags": "gi" },
    { "name": "Jailbreak keyword", "pattern": "jailbreak", "flags": "gi" },
    { "name": "Prompt extraction attempt", "pattern": "(?:reveal|show|tell\\s+me|output|print|display)\\s+(?:your|the)\\s+(?:system\\s+)?(?:prompt|instructions?|rules?|guidelines?)", "flags": "gi" },
    { "name": "Prompt extraction attempt", "pattern": "(?:what\\s+(?:are|is)\\s+your\\s+(?:system\\s+)?(?:prompt|instructions?|rules?))", "flags": "gi" },
    { "name": "Fake system message boundary", "pattern": "BEGIN\\s+(?:SYSTEM|ADMIN|NEW)\\s+(?:MESSAGE|PROMPT|INSTRUCTION)", "flags": "gi" },
    { "name": "Fake message boundary", "pattern": "END\\s+(?:OF\\s+)?(?:SYSTEM|USER)\\s+(?:MESSAGE|PROMPT|INPUT)", "flags": "gi" },
    { "name": "Fake XML system tags", "pattern": "</?(?:system|instruction|admin|prompt)>", "flags": "gi", "severity": "warning" },
    { "name": "Template injection pattern", "pattern": "\\{{2,}\\s*[^}]*?(?:system|prompt|instruction|ignore|forget|reveal|override|jailbreak|sudo|admin)[^}]*?\\}{2,}", "flags": "gi" },
    { "name": "Code execution pattern", "pattern": "eval\\s*\\(|exec\\s*\\(|Function\\s*\\(", "flags": "gi" },
    { "name": "SQL injection pattern", "pattern": "(?:DROP\\s+TABLE|DELETE\\s+FROM|INSERT\\s+INTO|UPDATE\\s+.*\\s+SET)\\s", "flags": "gi" },

    { "name": "ChatML role injection", "pattern": "<\\|im_start\\|>\\s*(?:system|user|assistant)", "flags": "gi" },
    { "name": "Llama3 role injection", "pattern": "<\\|start_header_id\\|>\\s*(?:system|assistant)\\s*<\\|end_header_id\\|>", "flags": "gi" },
    { "name": "ChatML role token", "pattern": "<\\|im_start\\|>", "flags": "gi", "severity": "warning" },
    { "name": "ChatML role token", "pattern": "<\\|im_end\\|>", "flags": "gi", "severity": "warning" },
    { "name": "Llama instruction token", "pattern": "\\[INST\\]", "flags": "g", "severity": "warning" },
    { "name": "Llama instruction token", "pattern": "\\[/INST\\]", "flags": "g", "severity": "warning" },
    { "name": "Chat role token", "pattern": "<\\|system\\|>", "flags": "gi", "severity": "warning" },
    { "name": "Chat role token", "pattern": "<\\|user\\|>", "flags": "gi", "severity": "warning" },
    { "name": "Chat role token", "pattern": "<\\|assistant\\|>", "flags": "gi", "severity": "warning" },
    { "name": "Llama3 header token", "pattern": "<\\|start_header_id\\|>", "flags": "gi", "severity": "warning" },
    { "name": "Llama3 header token", "pattern": "<\\|end_header_id\\|>", "flags": "gi", "severity": "warning" },
    { "name": "Chat boundary token", "pattern": "<\\|begin_of_text\\|>", "flags": "gi", "severity": "warning" },
    { "name": "Chat boundary token", "pattern": "<\\|end_of_text\\|>", "flags": "gi", "severity": "warning" },
    { "name": "Llama3 turn token", "pattern": "<\\|eot_id\\|>", "flags": "gi", "severity": "warning" },

    { "name": "Conversation turn marker", "pattern": "Human:\\s", "flags": "g", "severity": "warning" },
    { "name": "Conversation turn marker", "pattern": "Assistant:\\s", "flags": "g", "severity": "warning" },
    { "name": "Alpaca format marker", "pattern": "###\\s+Instruction\\b", "flags": "g", "severity": "warning" },
    { "name": "Alpaca format marker", "pattern": "###\\s+Response\\b", "flags": "g", "severity": "warning" },
    { "name": "Llama2 system marker", "pattern": "<<SYS>>", "flags": "g", "severity": "warning" },
    { "name": "Llama2 system marker", "pattern": "<</SYS>>", "flags": "g", "severity": "warning" },

    { "name": "Markdown heading impersonation", "pattern": "^\\s*#{1,6}\\s+(?:System|Assistant|User|Human|AI|Bot|Admin|Developer|Operator|Moderator)\\s*:", "flags": "gim", "severity": "warning" }
  ]
}
